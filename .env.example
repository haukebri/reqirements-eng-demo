# Required: Mistral AI API key for LLM agent orchestration
MISTRAL_API_KEY=your_mistral_api_key_here

# Database connection URL (PostgreSQL)
# When using docker-compose, this is set automatically.
# For local dev: create a local Postgres DB and set the URL here.
DATABASE_URL=postgres://reqai:reqai@localhost:5432/reqai

# Port the Express server listens on (default: 3001)
PORT=3001

# Set to "production" when running via Docker / docker-compose
NODE_ENV=development
